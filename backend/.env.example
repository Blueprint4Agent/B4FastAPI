# -------------------------------
# FastAPI server
# -------------------------------
APP_NAME=Blueprint4FastAPI API
APP_ENV=local
APP_PORT=8000
SWAGGER_ENABLED=true
CORS_ORIGINS=http://localhost:5173

# -------------------------------
# Auth
# -------------------------------
SECRET_KEY=CHANGE_ME_FOR_PRODUCTION
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
LOGIN_FAILED_LIMIT=5
LOGIN_LOCKED_MINUTES=5

# -------------------------------
# Database
# DB_DRIVER options:
#   sqlite+aiosqlite (default, easy local start)
#   postgresql+asyncpg (docker/postgres)
# -------------------------------
DB_DRIVER=sqlite+aiosqlite
DB_NAME=template.db
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres

# -------------------------------
# Redis
# REDIS_IN_MEMORY=true lets the API run without docker/external Redis.
# Turn this off when using real Redis.
# -------------------------------
REDIS_IN_MEMORY=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
